NODE_ENV=test
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=tasiburada_test
DB_POOL=5

# Optional: comma-separated exact hostnames for an explicitly approved remote CI test database.
TEST_DB_HOST_ALLOWLIST=

# M0A disposable MySQL harness (localhost and *_test targets only).
DISPOSABLE_DB_NAME=tasiburada_m0_local_test
ALLOW_DISPOSABLE_DB_CREATE=false
ALLOW_DISPOSABLE_DB_DROP=false
# Set this to exactly the disposable database name only for the drop command.
CONFIRM_DISPOSABLE_DB_DROP=
