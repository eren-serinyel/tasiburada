{
  "name": "tasiburada-backend",
  "version": "1.0.0",
  "description": "Taşıburada nakliyat platformu backend - Domain-driven architecture with TypeORM and MySQL",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate src/infrastructure/database/migrations/InitSchema -d src/infrastructure/database/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/infrastructure/database/data-source.ts",
    "migration:revert": "npx typeorm migration:revert -d src/infrastructure/database/data-source.ts",
    "seed:old": "npx ts-node src/seeds/seed.ts",
    "seed": "npx ts-node src/database/seed/seed.ts",
    "seed:clear": "npx ts-node -e \"require('reflect-metadata'); var ds = require('./src/infrastructure/database/data-source'); ds.initializeDatabase().then(function() { return require('./src/database/seed/clearDatabase').clearDatabase(); }).then(function() { return ds.closeDatabase(); }).then(function() { process.exit(0); })\"",
    "setup": "npm run migration:run && npm run seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "typeorm",
    "mysql",
    "express",
    "ddd",
    "nakliyat",
    "transportation"
  ],
  "author": "Taşıburada Development Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.4",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "jest": "^30.3.0",
    "prettier": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
