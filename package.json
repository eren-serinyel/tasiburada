{
  "name": "tasiburada-backend",
  "version": "1.0.0",
  "description": "Taşıburada nakliyat platformu backend - Domain-driven architecture with TypeORM and MySQL",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate src/infrastructure/database/migrations/InitSchema -d src/infrastructure/database/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/infrastructure/database/data-source.ts",
    "migration:revert": "npx typeorm migration:revert -d src/infrastructure/database/data-source.ts",
    "seed": "npx ts-node src/seeds/seed.ts",
    "setup": "npm run migration:run && npm run seed"
  },
  "keywords": ["nodejs", "typescript", "typeorm", "mysql", "express", "ddd", "nakliyat", "transportation"],
  "author": "Taşıburada Development Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typeorm": "^0.3.17",
    "mysql2": "^3.6.0",
    "reflect-metadata": "^0.1.13",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.4",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "prettier": "^3.0.1"
  }
}